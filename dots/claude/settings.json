{
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(which:*)",
      "Bash(diff:*)",
      "Bash(md5:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(cd:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git stash:*)",
      "Bash(git worktree:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(jq:*)",
      "Bash(tmux:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(npm list:*)",
      "Bash(npm ls:*)",
      "Bash(npm info:*)",
      "Bash(npm view:*)",
      "Bash(npm outdated:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(pip freeze:*)",
      "Bash(python --version:*)",
      "Bash(node -e:*)",
      "Bash(node --version:*)",
      "Bash(make lint:*)",
      "Bash(make test:*)",
      "Bash(make build:*)",
      "Bash(ruff:*)",
      "Bash(pytest:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run python:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv pip list:*)",
      "Bash(uv pip show:*)",
      "Bash(uv pip freeze:*)",
      "Bash(uv tree:*)",
      "Bash(uv version:*)",
      "WebSearch"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/bin/tmux-claude-notify",
            "async": true
          }
        ]
      }
    ]
  }
}
