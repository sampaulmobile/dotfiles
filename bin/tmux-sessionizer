#!/usr/bin/env bash

# Fuzzy find a project directory and create/switch to a tmux session for it.
# Based on ThePrimeagen's tmux-sessionizer.
#
# Worktree support: if a project directory contains a .bare/ subdir (the
# bare+worktree layout — see bin/gwclone), its immediate worktree subdirs
# are enumerated as separate entries. Session names become "<project>_<branch>"
# so two projects with the same branch name don't collide.

# ---- Options ----
SHOW_PERMISSION_INDICATORS=true
# -----------------

# ---- Project directories ----
# Add entries as "path:depth"
#   depth 0 = the directory itself is a project
#   depth 1 = search one level deep for projects inside it
search_dirs=(
    "$HOME/dev:1"
    "$HOME/research:1"
    "$HOME/dotfiles:0"
)
# ------------------------------

# Compute the tmux session name for a given project/worktree path.
# - For a worktree (parent contains .bare/), uses "<project>_<branch>".
# - Otherwise, uses basename of the path.
# Dots are translated to underscores (tmux session names don't love dots).
session_name_for() {
    local path="$1"
    local parent
    parent=$(dirname "$path")
    if [[ -d "$parent/.bare" ]]; then
        printf '%s_%s' "$(basename "$parent")" "$(basename "$path")" | tr . _
    else
        basename "$path" | tr . _
    fi
}

if [[ $# -eq 1 ]]; then
    selected=$1
else
    # Existing sessions sorted by most recently used (excluding current and claude-* popups)
    current_session=$(tmux display-message -p '#S')
    # If inside a claude popup, filter out the parent session instead
    if [[ "$current_session" == claude-* ]]; then
        filter_session="${current_session#claude-}"
    else
        filter_session="$current_session"
    fi
    existing=$(tmux list-sessions -F '#{session_last_attached} #{session_name}' 2>/dev/null |
        sort -rn |
        awk '{print $2}' |
        grep -v '^claude-' |
        grep -Fxv "$filter_session")

    # Project directories not yet opened as sessions
    candidates=()
    for entry in "${search_dirs[@]}"; do
        dir="${entry%%:*}"
        depth="${entry##*:}"
        if [[ $depth -eq 0 ]]; then
            raw=("$dir")
        else
            raw=($(find "$dir" -mindepth 1 -maxdepth "$depth" -type d))
        fi
        # For each raw candidate, expand worktree-layout projects into their
        # individual worktrees. Non-worktree dirs pass through as-is.
        for cand in "${raw[@]}"; do
            if [[ -d "$cand/.bare" ]]; then
                while IFS= read -r wt; do
                    [[ -n "$wt" ]] && candidates+=("$wt")
                done < <(find "$cand" -mindepth 1 -maxdepth 1 -type d ! -name '.bare')
            else
                candidates+=("$cand")
            fi
        done
    done

    # Annotate existing sessions with permission indicators
    if [[ "$SHOW_PERMISSION_INDICATORS" == true ]]; then
        _perm_dir=$(mktemp -d /tmp/sessionizer-perm.XXXXXX)
        while IFS= read -r _cs; do
            (
                _content=$(tmux capture-pane -t "${_cs}:1" -p -S -30 2>/dev/null | grep -v '^$' | tail -10)
                [[ -z "$_content" ]] && exit
                echo "$_content" | grep -q "to interrupt" && exit
                if echo "$_content" | grep -q "Yes" && echo "$_content" | grep -q "No"; then
                    echo "${_cs#claude-}" > "${_perm_dir}/${_cs}"
                fi
            ) &
        done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^claude-')
        wait
        _perm_sessions=$(cat "${_perm_dir}"/* 2>/dev/null)
        rm -rf "$_perm_dir"

        annotated=""
        while IFS= read -r _sess; do
            [[ -z "$_sess" ]] && continue
            if echo "$_perm_sessions" | grep -qx "$_sess"; then
                annotated+="${_sess} 🔴"$'\n'
            else
                annotated+="${_sess}"$'\n'
            fi
        done <<< "$existing"
    else
        annotated="$existing"$'\n'
    fi

    # Filter out dirs that already have a session
    new_dirs=""
    for dir in "${candidates[@]}"; do
        name=$(session_name_for "$dir")
        if ! echo "$existing" | grep -qx "$name"; then
            new_dirs+="$dir"$'\n'
        fi
    done

    selected=$( (
        printf '%s' "$annotated"
        printf '%s' "$new_dirs"
    ) | grep -v '^$' | fzf)

    # Strip permission indicator from selection
    [[ "$SHOW_PERMISSION_INDICATORS" == true ]] && selected="${selected% 🔴}"
fi

if [[ -z $selected ]]; then
    exit 0
fi

# If the selection is an existing session name (not a path), use it directly
if tmux has-session -t="$selected" 2>/dev/null; then
    selected_name="$selected"
else
    selected_name=$(session_name_for "$selected")
fi

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

# If inside a claude popup, close it and switch the parent client
# Keep the @claude_popup flag set so it auto-restores when switching back
current_session=$(tmux display-message -p '#S')
if [[ "$current_session" == claude-* ]]; then
    parent_session="${current_session#claude-}"
    client=$(tmux list-clients -t "$parent_session" -F '#{client_name}' | head -1)
    tmux detach-client
    sleep 0.1
    if [[ -n $client ]]; then
        tmux switch-client -c "$client" -t "$selected_name"
    fi
elif [[ -n $TMUX ]]; then
    tmux switch-client -t "$selected_name"
else
    tmux attach-session -t "$selected_name"
fi

# Auto-restore claude popup if the target session had one active
popup_flag=$(tmux show -qv -t "$selected_name" @claude_popup 2>/dev/null)
if [[ "$popup_flag" == "1" ]]; then
    popup_session="claude-${selected_name}"
    if tmux has-session -t="$popup_session" 2>/dev/null; then
        tmux display-popup -E -w 80% -h 80% "tmux attach-session -t '$popup_session'"
    fi
fi
